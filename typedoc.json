{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "out": "docs/api",
  "tsconfig": "tsconfig.json",
  "name": "@bitrix24/b24rabbitmq",
  "includeVersion": true,
  "readme": "README.md",
  "githubPages": false,
  "navigationLinks": {
    "GitHub": "https://github.com/bitrix24/b24rabbitmq",
    "npm": "https://www.npmjs.com/package/@bitrix24/b24rabbitmq"
  },
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeInternal": true,
  "excludeExternals": true,
  "skipErrorChecking": false,
  "treatWarningsAsErrors": true,
  "validation": {
    "notExported": true,
    "invalidLink": true,
    "notDocumented": false
  },
  "sort": ["source-order"]
}
