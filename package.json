{
  "name": "@bitrix24/b24rabbitmq",
  "version": "0.0.4",
  "author": "Bitrix",
  "description": "Library for integrating Bitrix24 applications with RabbitMQ",
  "keywords": [
    "Bitrix24",
    "RabbitMq",
    "typescript"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.10.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitrix24/b24rabbitmq.git"
  },
  "homepage": "https://github.com/bitrix24/b24rabbitmq",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "prepack": "pnpm run build",
    "build": "unbuild",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "translate-docs": "tsx tools/translate.docs.ts"
  },
  "dependencies": {
    "consola": "^3.4.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.25.5",
    "typescript": "^5.8.3",
    "unbuild": "^3.5.0",
    "eslint-config-unjs": "^0.4.2",
    "@types/amqplib": "^0.10.7",
    "tsx": "^4.19.4",
    "@types/node": "^22.15.23",
    "openai": "^4.103.0",
    "dotenv": "^16.5.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "amqplib": "^0.10.8"
  },
  "resolutions": {},
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "ignoredBuiltDependencies": []
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/esm/index.d.mts",
      "import": "./dist/esm/index.mjs"
    }
  },
  "main": "./dist/esm/index.mjs",
  "module": "./dist/esm/index.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/esm/index.d.mts"
      ]
    }
  },
  "files": [
    "README.md",
    "LICENSE",
    "dist",
    "package.json"
  ],
  "engines": {
    "node": "^20.0.0 || >=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
