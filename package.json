{
  "name": "@bitrix24/b24rabbitmq",
  "version": "0.0.4",
  "author": "Bitrix",
  "description": "Library for integrating Bitrix24 applications with RabbitMQ",
  "keywords": [
    "bitrix24",
    "rabbitmq",
    "amqp",
    "amqplib",
    "messaging",
    "queue",
    "producer",
    "consumer",
    "dead-letter",
    "typescript",
    "esm"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.10.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitrix24/b24rabbitmq.git"
  },
  "homepage": "https://github.com/bitrix24/b24rabbitmq",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "prepack": "pnpm run build",
    "build": "unbuild",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:build": "typedoc",
    "docs:watch": "typedoc --watch"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/amqplib": "^0.10.8",
    "@types/node": "^20.19.9",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.39.4",
    "eslint-config-unjs": "^0.6.2",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.2",
    "unbuild": "^3.6.1",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "amqplib": "^0.10.8"
  },
  "resolutions": {},
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "ignoredBuiltDependencies": []
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/esm/index.d.mts",
      "import": "./dist/esm/index.mjs"
    }
  },
  "main": "./dist/esm/index.mjs",
  "module": "./dist/esm/index.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/esm/index.d.mts"
      ]
    }
  },
  "files": [
    "README.md",
    "LICENSE",
    "dist",
    "package.json"
  ],
  "engines": {
    "node": "^20.0.0 || >=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
